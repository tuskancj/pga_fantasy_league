cells:
  - kind: 2
    languageId: sql
    value: "select distinct course.course_name\r

      from round\r

      inner join event on round.id_event = event.id_event\r

      inner join course on round.id_course = course.id_course\r

      where event.event_name like '%Waste%'\r

      limit 50;"
    metadata: {}
  - kind: 2
    languageId: sql
    value: "select player.player_name, dfs_total.total_pts from dfs_total \r

      inner join event on event.id_event = dfs_total.id_event\r

      inner join player on player.dg_id = dfs_total.dg_id\r

      where event.event_name like '%Farmer%' and event.calendar_year = 2026\r

      order by player.player_name"
    metadata: {}
  - kind: 2
    languageId: sql
    value: "select DISTINCT event.event_name\r

      from round\r

      inner join event on round.id_event = event.id_event\r

      inner join course on round.id_course = course.id_course\r

      where course.course_name in ('Torrey Pines (South)', 'Torrey Pines Golf
      Course (South Course)')\r

      limit 10;"
    metadata: {}
metadata:
